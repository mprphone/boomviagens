# Boomviagens - configuracao
PORT=3000
BASE_URL=http://localhost:3000

# Empresa
COMPANY_NAME=About Destiny, Unipessoal Lda
COMPANY_DOMAIN=boomviagens.pt
COMPANY_EMAIL=geral@boomviagens.pt
COMPANY_PHONE=+351960257333
COMPANY_NIF=509080308
COMPANY_RNAVT=INSERIR_NUMERO_RNAVT

# Backoffice
# Alterar obrigatoriamente antes de expor o site fora do ambiente local.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Sessoes (login admin e area de cliente)
# Valor aleatorio usado para assinar os cookies de sessao - obrigatorio em
# producao (sem isto, as sessoes ficam dependentes de ADMIN_PASSWORD).
SESSION_SECRET=gerar_um_valor_aleatorio_longo

# Dados comerciais
TOURDIEZ_AGENCY_CODE=
MARKET_COUNTRY=PT
CURRENCY=EUR
PRICE_TYPE=PVP
COMMISSION_INCLUDED=true
DEFAULT_MARGIN_PERCENT=5
CONFIRMATION_MODE=automatic

# Operador TourDiez / Sirio
# mock = funciona sem credenciais; real = tenta chamar a API externa.
# Ambiente de TEST: TOURDIEZ_BASE_URL=http://testapi.tourdiez.com/2.9/booking/ApiServlet.Srv
TOURDIEZ_MODE=mock
TOURDIEZ_BASE_URL=https://endpoint-do-operador.example/api
TOURDIEZ_USER=
TOURDIEZ_PASSWORD=

# Pagamentos
# Vamos testar ate ao pagamento em mock e decidir gateway depois.
PAYMENTS_MODE=mock
PAYMENT_GATEWAY=decidir_depois

# Base de dados
# local = JSON para desenvolvimento; supabase = Postgres gerido em Supabase.
DB_MODE=local
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=colocar_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=colocar_service_role_key_apenas_no_env_local

# IA / chat
# Sem chave externa, usa regras locais. Pode ligar depois a OpenAI/Gemini.
AI_MODE=local
AI_API_KEY=
